# Copy this to .env.local for release builds. Do not commit .env.local.

# Developer ID Application certificate name from Keychain.
# Example: Developer ID Application: Your Name (TEAMID1234)
SHOTNIX_CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID1234)"

# notarytool Keychain profile created with:
# xcrun notarytool store-credentials "ShotnixNotaryProfile"
SHOTNIX_NOTARY_PROFILE="ShotnixNotaryProfile"

# Optional: override output DMG passed to notarize-dmg.sh.
# SHOTNIX_DMG_PATH="/absolute/path/to/Shotnix-v0.15.4-beta-macOS.dmg"

# Required for Developer ID builds with Sparkle enabled. This is the public
# EdDSA key from Sparkle's generate_keys tool. Never commit the private key.
# SHOTNIX_SPARKLE_PUBLIC_ED_KEY=""

# Optional account name used by Sparkle generate_keys/generate_appcast.
# Keep this consistent across machines.
# SHOTNIX_SPARKLE_ACCOUNT="ed25519"

# Set to true for official releases so build-app.sh fails instead of shipping
# a build whose Check for Updates menu item is disabled.
# SHOTNIX_REQUIRE_SPARKLE_KEY=true

# Optional: public release label used by make-dmg.sh. The app bundle version
# stays beta-free, but public downloads can keep the beta suffix.
# SHOTNIX_PUBLIC_VERSION="0.15.4-beta"
